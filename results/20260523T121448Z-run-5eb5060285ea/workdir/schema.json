{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["event_type", "payload"],
  "properties": {
    "event_type": { "type": "string", "enum": ["user_signup", "user_deletion"] },
    "payload": { "type": "object" }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if":   { "properties": { "event_type": { "const": "user_signup" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["email", "country"],
            "properties": {
              "email":   { "type": "string", "pattern": "^[^@]+@[^@]+\\.[^@]+$" },
              "country": { "type": "string", "pattern": "^[A-Z]{2}$" }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if":   { "properties": { "event_type": { "const": "user_deletion" } }, "required": ["event_type"] },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": ["user_id", "reason"],
            "properties": {
              "user_id": { "type": "string", "pattern": "^u-[0-9]+$" },
              "reason":  { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ]
}
