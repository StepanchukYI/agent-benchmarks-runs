{
  "tools": [
    {
      "name": "upload_blob",
      "description": "Upload a base64-encoded binary blob. The `data` field MUST be valid base64. Use lowercase content_type.",
      "parameters": {
        "type": "object",
        "properties": {
          "filename":     { "type": "string", "minLength": 1 },
          "content_type": { "type": "string", "pattern": "^[a-z0-9.+\\-/]+$" },
          "data":         { "type": "string", "minLength": 1 }
        },
        "required": ["filename", "content_type", "data"],
        "additionalProperties": false
      }
    }
  ]
}
