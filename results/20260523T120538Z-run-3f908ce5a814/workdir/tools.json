        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" }
        },
        "required": ["url"],
        "additionalProperties": false
      },
      "_test_behavior": {
        "always_returns_error": "DNS_RESOLUTION_FAILED"
      }
    }
  ]
}
