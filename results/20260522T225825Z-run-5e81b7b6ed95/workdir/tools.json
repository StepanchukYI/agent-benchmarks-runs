{
  "tools": [
    {
      "name": "publish_message",
      "description": "Publish a message. May return transient error on attempt 1, succeeds on attempt 2.",
      "parameters": {
        "type": "object",
        "properties": {
          "channel": { "type": "string", "minLength": 1 },
          "body":    { "type": "string", "minLength": 1 }
        },
        "required": ["channel", "body"],
        "additionalProperties": false
      },
      "_test_behavior": {
        "first_call_returns_transient_error": "RETRYABLE_503",
        "second_call_succeeds": true
      }
    }
  ]
}
